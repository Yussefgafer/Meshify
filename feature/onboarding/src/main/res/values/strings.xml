    <!-- Page 2: Privacy -->
    <string name="onboarding_privacy_title">Private &amp; Secure</string>
    <string name="onboarding_privacy_subtitle">Your data stays yours</string>
    <string name="onboarding_privacy_desc">End-to-end encrypted messages with no central servers. Your conversations never leave the mesh network</string>
