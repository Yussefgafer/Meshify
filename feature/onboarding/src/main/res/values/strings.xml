    <string name="perm_storage_what_happens_1">Select images to send</string>
    <string name="perm_storage_what_happens_2">Share files with peers</string>
    <string name="perm_storage_if_deny_1">Cannot send images</string>
    <string name="perm_storage_if_deny_2">Cannot share files</string>
